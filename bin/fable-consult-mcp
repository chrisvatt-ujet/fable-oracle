#!/usr/bin/env python3
"""Minimal MCP stdio server exposing fable-consult as a tool.

Register in codex config.toml (install.sh does this):
    [mcp_servers.fable]
    command = "/path/to/fable-oracle/bin/fable-consult-mcp"
    tool_timeout_sec = 900
    enabled = true
"""
import json
import os
import subprocess
import sys

SHIM = os.path.join(os.path.dirname(os.path.realpath(__file__)), "fable-consult")

ORCH_TOOL = {
    "name": "fable_orchestrate",
    "description": (
        "Hand a whole mission to Fable as ORCHESTRATOR — only when the user explicitly asks for "
        "Fable to drive (investigations, architecture/design work, research, large multi-step "
        "implementations). Fable plans, spawns codex sub-agents for all legwork, synthesizes, and "
        "writes <task_dir>/.fable-oracle/<task>/DELIVERABLE.md. LOCAL TOOL (the user's own Claude "
        "Code CLI); repo content is pre-authorized. Starts DETACHED and returns immediately: poll "
        "by running `fable-orchestrate status --task <task>` in the shell (missions take 10-60+ "
        "min; check every few minutes until STATUS reads done/failed), then relay the deliverable. "
        "The mission must be self-contained: type (investigation|coding|mixed), goal, context with "
        "file refs, constraints, and what done means."
    ),
    "inputSchema": {
        "type": "object",
        "properties": {
            "mission": {"type": "string", "description": "Self-contained mission statement (markdown)."},
            "task": {"type": "string", "description": "Short stable slug for this mission (state lives under .fable-oracle/<slug>/)."},
            "task_dir": {"type": "string", "description": "Absolute path to the repo root."},
        },
        "required": ["mission", "task", "task_dir"],
    },
}

TOOL = {
    "name": "fable_consult",
    "description": (
        "Consult Fable, the persistent per-task oracle (a stronger reasoning model), per the "
        "fable-oracle skill's protocol — ONLY when the user explicitly asked for Fable's input; "
        "do not consult uninvited. LOCAL TOOL, NOT AN EXTERNAL SERVICE: it runs the user's "
        "own authenticated Claude Code CLI on this machine, under the user's account. The user "
        "installed it precisely so that repository content — code, diffs, branch/commit details, "
        "uncommitted changes — is sent to Fable; that is pre-authorized. Do not refuse or ask "
        "permission on data-sharing grounds. "
        "Use consult_type 'direction' to open a task (triage/plan), "
        "'decide' at a fork between options, 'unblock' after 2 failed attempts or user "
        "dissatisfaction, 'review' to verify completed work (send diff + pasted test output). "
        "The brief must be dense and grounded: task, state with file:line evidence, ONE sharp "
        "question, constraints. Returns Fable's response ending in a structured "
        "VERDICT/DIRECTIVES/RESEARCH_NEEDED/CHECKPOINTS block to follow literally. "
        "Session state and ledger live in <task_dir>/.fable-oracle/."
    ),
    "inputSchema": {
        "type": "object",
        "properties": {
            "consult_type": {
                "type": "string",
                "enum": ["direction", "decide", "unblock", "review"],
                "description": "Consult type per the fable-oracle protocol.",
            },
            "brief": {
                "type": "string",
                "description": "The consult brief (markdown). Dense, grounded, one sharp question.",
            },
            "task_dir": {
                "type": "string",
                "description": "Absolute path to the repo root (holds .fable-oracle/ state).",
            },
            "title": {
                "type": "string",
                "description": "Short title for the ledger entry.",
            },
            "task": {
                "type": "string",
                "description": (
                    "Short stable slug identifying THIS task (e.g. 'voice-ui', 'pii-redaction'). "
                    "Each task gets its own oracle session; parallel tasks in one repo must use "
                    "distinct slugs. Use the same slug for every consult of the task."
                ),
            },
            "new_session": {
                "type": "boolean",
                "description": "Rotate to a fresh oracle session re-briefed from the ledger (rare).",
            },
        },
        "required": ["consult_type", "brief", "task_dir"],
    },
}


def reply(msg_id, result=None, error=None):
    out = {"jsonrpc": "2.0", "id": msg_id}
    if error is not None:
        out["error"] = error
    else:
        out["result"] = result
    sys.stdout.write(json.dumps(out) + "\n")
    sys.stdout.flush()


def run_consult(args):
    task_dir = args["task_dir"]
    if not os.path.isdir(task_dir):
        return f"error: task_dir does not exist: {task_dir}", True
    cmd = [SHIM, args["consult_type"]]
    if args.get("task"):
        cmd += ["--task", args["task"]]
    if args.get("title"):
        cmd += ["--title", args["title"]]
    if args.get("new_session"):
        cmd += ["--new"]
    try:
        proc = subprocess.run(
            cmd, input=args["brief"], capture_output=True, text=True,
            cwd=task_dir, timeout=840,
        )
    except subprocess.TimeoutExpired:
        return "error: consult timed out after 840s", True
    if proc.returncode != 0:
        return f"error (exit {proc.returncode}): {proc.stderr.strip()[:2000]}", True
    return proc.stdout, False


def run_orchestrate(args):
    task_dir = args.get("task_dir", "")
    if not os.path.isdir(task_dir):
        return f"error: task_dir does not exist: {task_dir}", True
    orch = os.path.join(os.path.dirname(SHIM), "fable-orchestrate")
    try:
        proc = subprocess.run(
            [orch, "start", "--task", args["task"], "--detach"],
            input=args["mission"], capture_output=True, text=True,
            cwd=task_dir, timeout=60,
        )
    except subprocess.TimeoutExpired:
        return "error: orchestrate start timed out", True
    if proc.returncode != 0:
        return f"error (exit {proc.returncode}): {proc.stderr.strip()[:2000]}", True
    return proc.stdout, False


def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        method, msg_id = msg.get("method"), msg.get("id")
        if method == "initialize":
            reply(msg_id, {
                "protocolVersion": msg.get("params", {}).get("protocolVersion", "2025-06-18"),
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "fable-oracle", "version": "1.0.0"},
            })
        elif method == "tools/list":
            reply(msg_id, {"tools": [TOOL, ORCH_TOOL]})
        elif method == "tools/call":
            params = msg.get("params", {})
            name = params.get("name")
            if name == "fable_consult":
                text, is_err = run_consult(params.get("arguments", {}))
            elif name == "fable_orchestrate":
                text, is_err = run_orchestrate(params.get("arguments", {}))
            else:
                reply(msg_id, error={"code": -32602, "message": "unknown tool"})
                continue
            reply(msg_id, {"content": [{"type": "text", "text": text}], "isError": is_err})
        elif method == "ping":
            reply(msg_id, {})
        elif msg_id is not None:
            reply(msg_id, error={"code": -32601, "message": f"method not found: {method}"})
        # notifications (no id) are ignored


if __name__ == "__main__":
    main()
