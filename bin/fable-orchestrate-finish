#!/usr/bin/env python3
"""Post-process a fable-orchestrate run: parse orchestrator-out.json into
ORCHESTRATOR_REPORT.md + session.json + STATUS. Prints the report."""
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
try:
    out = json.loads((d / "orchestrator-out.json").read_text())
except Exception as e:  # noqa: BLE001
    (d / "STATUS").write_text(f"failed: unparseable output ({e})\n")
    sys.exit(1)
report = out.get("result") or ""
(d / "ORCHESTRATOR_REPORT.md").write_text(report)
(d / "session.json").write_text(json.dumps({"session_id": out.get("session_id")}, indent=2))
(d / "STATUS").write_text("failed: model returned error\n" if out.get("is_error") else "done\n")
print(report)
